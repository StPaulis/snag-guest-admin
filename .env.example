# Copy to .env.local and fill in.

# snag-api base URL (no trailing slash). Staging:
VITE_API_URL=https://api-staging.services.joinsnag.com

# Firebase Web API key (same project as snag-api; FIREBASE_CLIENT_API_KEY server-side)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=

# Tenant (partner company) config — until dedicated guest-admin endpoints exist,
# data is scoped client-side by the host user that owns the listings.
VITE_TENANT_NAME=Loft Collective
VITE_TENANT_INITIALS=LC
VITE_TENANT_SUBDOMAIN=team-a
VITE_TENANT_HOST_USER_ID=

# Set to "true" to run fully on in-memory mock data (no API / auth needed)
VITE_USE_MOCKS=true
