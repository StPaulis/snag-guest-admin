# Copy to .env.local and fill in.

# snag-api base URL (no trailing slash). Local dev backend with /admin-guest module:
VITE_API_URL=http://localhost:3025
# Staging: https://api-staging.services.joinsnag.com

# Firebase Web API key (same project as snag-api; FIREBASE_CLIENT_API_KEY server-side)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=

# Tenant (partner company) config. Data scoping is server-side (the guest-admin role
# is scoped to a company), but HOST_USER_ID is still required for chat: it decides
# the me/them message perspective and is the sender userId when posting messages.
VITE_TENANT_NAME=Loft Collective
VITE_TENANT_INITIALS=LC
VITE_TENANT_SUBDOMAIN=team-a
VITE_TENANT_HOST_USER_ID=

# Set to "true" to run fully on in-memory mock data (no API / auth needed)
VITE_USE_MOCKS=true
